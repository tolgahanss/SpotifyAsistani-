<Window x:Class="SpotifyAsistani.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Spotify Asistanı"
        Height="780" Width="1200"
        MinHeight="600" MinWidth="900"
        WindowStartupLocation="CenterScreen"
        Background="#0a0a0f"
        Loaded="Window_Loaded">

    <Window.Resources>
        <!-- ===== Renkler ===== -->
        <Color x:Key="SpotifyGreen">#1DB954</Color>
        <Color x:Key="SpotifyGreenLight">#1ed760</Color>
        <Color x:Key="BgPrimary">#0a0a0f</Color>
        <Color x:Key="BgSecondary">#111118</Color>
        <Color x:Key="BgCard">#19192380</Color>
        <Color x:Key="TextPrimary">#FFFFFF</Color>
        <Color x:Key="TextSecondary">#a1a1aa</Color>
        <Color x:Key="TextMuted">#52525b</Color>
        <Color x:Key="BorderColor">#1a1a1a</Color>
        <Color x:Key="AccentPurple">#8b5cf6</Color>
        <Color x:Key="AccentPink">#ec4899</Color>
        <Color x:Key="AccentBlue">#3b82f6</Color>

        <SolidColorBrush x:Key="SpotifyGreenBrush" Color="{StaticResource SpotifyGreen}"/>
        <SolidColorBrush x:Key="SpotifyGreenLightBrush" Color="{StaticResource SpotifyGreenLight}"/>
        <SolidColorBrush x:Key="BgPrimaryBrush" Color="{StaticResource BgPrimary}"/>
        <SolidColorBrush x:Key="BgSecondaryBrush" Color="{StaticResource BgSecondary}"/>
        <SolidColorBrush x:Key="TextPrimaryBrush" Color="{StaticResource TextPrimary}"/>
        <SolidColorBrush x:Key="TextSecondaryBrush" Color="{StaticResource TextSecondary}"/>
        <SolidColorBrush x:Key="TextMutedBrush" Color="{StaticResource TextMuted}"/>
        <SolidColorBrush x:Key="BorderBrush" Color="{StaticResource BorderColor}"/>
        <SolidColorBrush x:Key="AccentPurpleBrush" Color="{StaticResource AccentPurple}"/>
        <SolidColorBrush x:Key="AccentPinkBrush" Color="{StaticResource AccentPink}"/>
        <SolidColorBrush x:Key="AccentBlueBrush" Color="{StaticResource AccentBlue}"/>

        <!-- ===== Glassmorphism Card Style ===== -->
        <Style x:Key="GlassCard" TargetType="Border">
            <Setter Property="Background">
                <Setter.Value>
                    <SolidColorBrush Color="#191923" Opacity="0.85"/>
                </Setter.Value>
            </Setter>
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="16"/>
            <Setter Property="Padding" Value="20"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect BlurRadius="20" ShadowDepth="2" Opacity="0.3" Color="Black"/>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ===== Primary Button Style ===== -->
        <Style x:Key="PrimaryButton" TargetType="Button">
            <Setter Property="Background">
                <Setter.Value>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Color="{StaticResource SpotifyGreenLight}" Offset="0"/>
                        <GradientStop Color="{StaticResource SpotifyGreen}" Offset="1"/>
                    </LinearGradientBrush>
                </Setter.Value>
            </Setter>
            <Setter Property="Foreground" Value="#000"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="Padding" Value="24,12"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}" 
                                CornerRadius="24" Padding="{TemplateBinding Padding}"
                                BorderThickness="0">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="RenderTransform">
                                    <Setter.Value>
                                        <ScaleTransform ScaleX="1.03" ScaleY="1.03"/>
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ===== Secondary Button Style ===== -->
        <Style x:Key="SecondaryButton" TargetType="Button">
            <Setter Property="Background">
                <Setter.Value>
                    <SolidColorBrush Color="White" Opacity="0.06"/>
                </Setter.Value>
            </Setter>
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
            <Setter Property="FontWeight" Value="Medium"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="Padding" Value="16,8"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}" 
                                CornerRadius="20" Padding="{TemplateBinding Padding}"
                                BorderBrush="{StaticResource BorderBrush}" BorderThickness="1">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background">
                                    <Setter.Value>
                                        <SolidColorBrush Color="White" Opacity="0.1"/>
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ===== Nav Tab Button Style ===== -->
        <Style x:Key="NavTab" TargetType="RadioButton">
            <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="Medium"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border x:Name="border" Background="Transparent" CornerRadius="20" Padding="16,8" Margin="2,0">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background">
                                    <Setter.Value>
                                        <SolidColorBrush Color="White" Opacity="0.06"/>
                                    </Setter.Value>
                                </Setter>
                                <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="border" Property="Background">
                                    <Setter.Value>
                                        <SolidColorBrush Color="{StaticResource SpotifyGreen}" Opacity="0.15"/>
                                    </Setter.Value>
                                </Setter>
                                <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
                                <Setter Property="FontWeight" Value="SemiBold"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ===== TextBox Style ===== -->
        <Style x:Key="ModernTextBox" TargetType="TextBox">
            <Setter Property="Background">
                <Setter.Value>
                    <SolidColorBrush Color="White" Opacity="0.05"/>
                </Setter.Value>
            </Setter>
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="12,10"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="CaretBrush" Value="{StaticResource SpotifyGreenBrush}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border x:Name="border" Background="{TemplateBinding Background}" 
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8">
                            <ScrollViewer x:Name="PART_ContentHost" Margin="2,0"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter TargetName="border" Property="BorderBrush" Value="{StaticResource SpotifyGreenBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <!-- ===== Background Gradient ===== -->
    <Grid>
        <Grid.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                <GradientStop Color="#0a0a0f" Offset="0"/>
                <GradientStop Color="#0d0d14" Offset="0.5"/>
                <GradientStop Color="#0a0a0f" Offset="1"/>
            </LinearGradientBrush>
        </Grid.Background>

        <!-- Decorative gradient circles -->
        <Ellipse Width="600" Height="400" HorizontalAlignment="Left" VerticalAlignment="Top" Margin="-100,-100,0,0" Opacity="0.06">
            <Ellipse.Fill>
                <RadialGradientBrush>
                    <GradientStop Color="{StaticResource SpotifyGreen}" Offset="0"/>
                    <GradientStop Color="Transparent" Offset="1"/>
                </RadialGradientBrush>
            </Ellipse.Fill>
        </Ellipse>
        <Ellipse Width="500" Height="500" HorizontalAlignment="Right" VerticalAlignment="Bottom" Margin="0,0,-100,-100" Opacity="0.04">
            <Ellipse.Fill>
                <RadialGradientBrush>
                    <GradientStop Color="{StaticResource AccentPurple}" Offset="0"/>
                    <GradientStop Color="Transparent" Offset="1"/>
                </RadialGradientBrush>
            </Ellipse.Fill>
        </Ellipse>

        <DockPanel>
            <!-- ===== NAVBAR ===== -->
            <Border DockPanel.Dock="Top" Padding="24,14" BorderThickness="0,0,0,1" BorderBrush="{StaticResource BorderBrush}">
                <Border.Background>
                    <SolidColorBrush Color="#0a0a0f" Opacity="0.9"/>
                </Border.Background>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- Logo + Title -->
                    <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                        <Border Width="34" Height="34" CornerRadius="8" Margin="0,0,10,0">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                    <GradientStop Color="{StaticResource SpotifyGreenLight}" Offset="0"/>
                                    <GradientStop Color="{StaticResource SpotifyGreen}" Offset="1"/>
                                </LinearGradientBrush>
                            </Border.Background>
                            <TextBlock Text="♫" FontSize="18" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="Black" FontWeight="Bold"/>
                        </Border>
                        <TextBlock Text="Spotify Asistanı" FontSize="18" FontWeight="Bold" VerticalAlignment="Center" Foreground="{StaticResource SpotifyGreenBrush}"/>
                    </StackPanel>

                    <!-- Navigation Tabs -->
                    <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                        <RadioButton x:Name="TabDashboard" Content="🏠 Ana Sayfa" Style="{StaticResource NavTab}" IsChecked="True" Checked="Tab_Changed" GroupName="MainNav"/>
                        <RadioButton x:Name="TabStats" Content="📊 İstatistikler" Style="{StaticResource NavTab}" Checked="Tab_Changed" GroupName="MainNav"/>
                        <RadioButton x:Name="TabPlaylists" Content="🎵 Çalma Listeleri" Style="{StaticResource NavTab}" Checked="Tab_Changed" GroupName="MainNav"/>
                        <RadioButton x:Name="TabSettings" Content="⚙️ Ayarlar" Style="{StaticResource NavTab}" Checked="Tab_Changed" GroupName="MainNav"/>
                    </StackPanel>

                    <!-- Status -->
                    <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                        <Ellipse x:Name="StatusDot" Width="8" Height="8" Margin="0,0,8,0">
                            <Ellipse.Fill>
                                <SolidColorBrush Color="#ef4444"/>
                            </Ellipse.Fill>
                        </Ellipse>
                        <TextBlock x:Name="StatusText" Text="Bağlı Değil" FontSize="12" Foreground="{StaticResource TextMutedBrush}" VerticalAlignment="Center"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- ===== MAIN CONTENT ===== -->
            <Grid Margin="24">
                <!-- Login Page -->
                <Grid x:Name="LoginPage" Visibility="Visible">
                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Width="520">
                        <TextBlock Text="🎧" FontSize="72" HorizontalAlignment="Center" Margin="0,0,0,16"/>
                        <TextBlock Text="Spotify Asistanı" FontSize="42" FontWeight="ExtraBold" HorizontalAlignment="Center" Margin="0,0,0,8" Foreground="{StaticResource TextPrimaryBrush}"/>
                        <TextBlock Text="Müziğinizi takip edin, istatistikleri görün ve akıllı çalma listeleri oluşturun." 
                                   FontSize="16" Foreground="{StaticResource TextSecondaryBrush}" HorizontalAlignment="Center" TextAlignment="Center" TextWrapping="Wrap" Margin="0,0,0,32"/>

                        <!-- API Credentials -->
                        <Border Style="{StaticResource GlassCard}" Margin="0,0,0,16">
                            <StackPanel>
                                <TextBlock Text="Spotify API Bilgileri" FontSize="16" FontWeight="SemiBold" Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,16"/>
                                
                                <TextBlock Text="Client ID" FontSize="13" FontWeight="Medium" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,6"/>
                                <TextBox x:Name="TxtClientId" Style="{StaticResource ModernTextBox}" Margin="0,0,0,12"/>
                                
                                <TextBlock Text="Client Secret" FontSize="13" FontWeight="Medium" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,6"/>
                                <TextBox x:Name="TxtClientSecret" Style="{StaticResource ModernTextBox}" Margin="0,0,0,16"/>

                                <Button Content="🔗 Spotify ile Bağlan" Style="{StaticResource PrimaryButton}" Click="ConnectSpotify_Click" HorizontalAlignment="Stretch"/>
                            </StackPanel>
                        </Border>

                        <TextBlock TextWrapping="Wrap" TextAlignment="Center" FontSize="12" Foreground="{StaticResource TextMutedBrush}" Margin="0,8,0,0">
                            <Run Text="API anahtarlarınızı "/>
                            <Hyperlink NavigateUri="https://developer.spotify.com/dashboard" RequestNavigate="Hyperlink_RequestNavigate" Foreground="{StaticResource SpotifyGreenBrush}">developer.spotify.com</Hyperlink>
                            <Run Text=" adresinden ücretsiz oluşturabilirsiniz. Redirect URI olarak "/>
                            <Run Text="http://127.0.0.1:8391/callback" FontWeight="SemiBold" Foreground="{StaticResource TextSecondaryBrush}"/>
                            <Run Text=" ekleyin."/>
                        </TextBlock>
                    </StackPanel>
                </Grid>

                <!-- Dashboard Page -->
                <Grid x:Name="DashboardPage" Visibility="Collapsed">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="360"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Sol: Now Playing + Lyrics -->
                    <StackPanel Grid.Column="0" Margin="0,0,16,0">
                        <!-- Now Playing Card -->
                        <Border Style="{StaticResource GlassCard}" Margin="0,0,0,16">
                            <StackPanel>
                                <!-- Header -->
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                                    <Ellipse x:Name="NowPlayingDot" Width="8" Height="8" Fill="{StaticResource SpotifyGreenBrush}" Margin="0,0,8,0"/>
                                    <TextBlock x:Name="NowPlayingLabel" Text="ŞU AN ÇALIYOR" FontSize="11" FontWeight="SemiBold" Foreground="{StaticResource SpotifyGreenBrush}" VerticalAlignment="Center"/>
                                </StackPanel>

                                <!-- Album Art -->
                                <Border CornerRadius="12" Margin="0,0,0,16" ClipToBounds="True">
                                    <Image x:Name="AlbumArt" Stretch="UniformToFill" Height="300"/>
                                </Border>

                                <!-- Track Info -->
                                <TextBlock x:Name="TrackTitle" Text="Çalan Şarkı Yok" FontSize="18" FontWeight="Bold" Foreground="{StaticResource TextPrimaryBrush}" TextTrimming="CharacterEllipsis"/>
                                <TextBlock x:Name="TrackArtist" Text="Spotify'da bir şarkı çalın" FontSize="14" Foreground="{StaticResource TextSecondaryBrush}" TextTrimming="CharacterEllipsis" Margin="0,4,0,0"/>
                                <TextBlock x:Name="TrackAlbum" FontSize="12" Foreground="{StaticResource TextMutedBrush}" TextTrimming="CharacterEllipsis" Margin="0,2,0,0"/>

                                <!-- Progress Bar -->
                                <Grid Margin="0,14,0,0">
                                    <Border Height="4" CornerRadius="2" Background="#1a1a1a"/>
                                    <Border x:Name="ProgressBar" Height="4" CornerRadius="2" HorizontalAlignment="Left" Width="0">
                                        <Border.Background>
                                            <SolidColorBrush Color="{StaticResource SpotifyGreen}"/>
                                        </Border.Background>
                                    </Border>
                                </Grid>
                                <Grid Margin="0,6,0,0">
                                    <TextBlock x:Name="ProgressTime" Text="0:00" FontSize="11" Foreground="{StaticResource TextMutedBrush}" HorizontalAlignment="Left"/>
                                    <TextBlock x:Name="DurationTime" Text="0:00" FontSize="11" Foreground="{StaticResource TextMutedBrush}" HorizontalAlignment="Right"/>
                                </Grid>
                            </StackPanel>
                        </Border>

                        <!-- Lyrics Card -->
                        <Border Style="{StaticResource GlassCard}" MaxHeight="300">
                            <StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                                    <TextBlock Text="📝" FontSize="16" Margin="0,0,8,0"/>
                                    <TextBlock Text="ŞARKI SÖZLERİ" FontSize="11" FontWeight="SemiBold" Foreground="{StaticResource TextSecondaryBrush}" VerticalAlignment="Center"/>
                                </StackPanel>
                                <ScrollViewer MaxHeight="220" VerticalScrollBarVisibility="Auto">
                                    <TextBlock x:Name="LyricsText" Text="Şarkı çalınırken sözler burada görünecek..." 
                                               FontSize="14" Foreground="{StaticResource TextSecondaryBrush}" 
                                               TextWrapping="Wrap" LineHeight="28"/>
                                </ScrollViewer>
                            </StackPanel>
                        </Border>
                    </StackPanel>

                    <!-- Sağ: Stats Overview + Top Tracks -->
                    <StackPanel Grid.Column="1" Margin="8,0,0,0">
                        <!-- Mini Stats Cards -->
                        <Grid Margin="0,0,0,16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <Border Grid.Column="0" Style="{StaticResource GlassCard}" Margin="0,0,8,0">
                                <StackPanel HorizontalAlignment="Center">
                                    <TextBlock Text="🎵" FontSize="24" HorizontalAlignment="Center" Margin="0,0,0,6"/>
                                    <TextBlock x:Name="StatTotalTracks" Text="0" FontSize="26" FontWeight="ExtraBold" HorizontalAlignment="Center" Foreground="{StaticResource TextPrimaryBrush}"/>
                                    <TextBlock Text="ŞARKI" FontSize="10" Foreground="{StaticResource TextMutedBrush}" HorizontalAlignment="Center"/>
                                </StackPanel>
                            </Border>

                            <Border Grid.Column="1" Style="{StaticResource GlassCard}" Margin="4,0,4,0">
                                <StackPanel HorizontalAlignment="Center">
                                    <TextBlock Text="🔄" FontSize="24" HorizontalAlignment="Center" Margin="0,0,0,6"/>
                                    <TextBlock x:Name="StatTotalPlays" Text="0" FontSize="26" FontWeight="ExtraBold" HorizontalAlignment="Center" Foreground="{StaticResource TextPrimaryBrush}"/>
                                    <TextBlock Text="DİNLEME" FontSize="10" Foreground="{StaticResource TextMutedBrush}" HorizontalAlignment="Center"/>
                                </StackPanel>
                            </Border>

                            <Border Grid.Column="2" Style="{StaticResource GlassCard}" Margin="4,0,4,0">
                                <StackPanel HorizontalAlignment="Center">
                                    <TextBlock Text="⏱️" FontSize="24" HorizontalAlignment="Center" Margin="0,0,0,6"/>
                                    <TextBlock x:Name="StatTotalTime" Text="0dk" FontSize="26" FontWeight="ExtraBold" HorizontalAlignment="Center" Foreground="{StaticResource TextPrimaryBrush}"/>
                                    <TextBlock Text="SÜRE" FontSize="10" Foreground="{StaticResource TextMutedBrush}" HorizontalAlignment="Center"/>
                                </StackPanel>
                            </Border>

                            <Border Grid.Column="3" Style="{StaticResource GlassCard}" Margin="8,0,0,0">
                                <StackPanel HorizontalAlignment="Center">
                                    <TextBlock Text="📅" FontSize="24" HorizontalAlignment="Center" Margin="0,0,0,6"/>
                                    <TextBlock x:Name="StatTodayPlays" Text="0" FontSize="26" FontWeight="ExtraBold" HorizontalAlignment="Center" Foreground="{StaticResource TextPrimaryBrush}"/>
                                    <TextBlock Text="BUGÜN" FontSize="10" Foreground="{StaticResource TextMutedBrush}" HorizontalAlignment="Center"/>
                                </StackPanel>
                            </Border>
                        </Grid>

                        <!-- Top Tracks -->
                        <Border Style="{StaticResource GlassCard}">
                            <StackPanel>
                                <Grid Margin="0,0,0,12">
                                    <TextBlock Text="🏆 En Çok Dinlenen Şarkılar" FontSize="16" FontWeight="SemiBold" Foreground="{StaticResource TextPrimaryBrush}" VerticalAlignment="Center"/>
                                    <TextBlock Text="Uygulama çalışırken güncellenir" FontSize="11" Foreground="{StaticResource TextMutedBrush}" HorizontalAlignment="Right" VerticalAlignment="Center"/>
                                </Grid>
                                <ScrollViewer MaxHeight="440" VerticalScrollBarVisibility="Auto">
                                    <ItemsControl x:Name="TopTracksList">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border Padding="8,10" CornerRadius="8" Margin="0,1" Cursor="Hand">
                                                    <Border.Style>
                                                        <Style TargetType="Border">
                                                            <Setter Property="Background" Value="Transparent"/>
                                                            <Style.Triggers>
                                                                <Trigger Property="IsMouseOver" Value="True">
                                                                    <Setter Property="Background">
                                                                        <Setter.Value>
                                                                            <SolidColorBrush Color="White" Opacity="0.04"/>
                                                                        </Setter.Value>
                                                                    </Setter>
                                                                </Trigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Border.Style>
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="36"/>
                                                            <ColumnDefinition Width="46"/>
                                                            <ColumnDefinition Width="*"/>
                                                            <ColumnDefinition Width="80"/>
                                                            <ColumnDefinition Width="90"/>
                                                        </Grid.ColumnDefinitions>

                                                        <!-- Rank -->
                                                        <TextBlock Grid.Column="0" Text="{Binding Rank}" FontSize="14" FontWeight="SemiBold" 
                                                                   Foreground="{Binding RankColor}" VerticalAlignment="Center" HorizontalAlignment="Center"/>

                                                        <!-- Album Art -->
                                                        <Border Grid.Column="1" Width="40" Height="40" CornerRadius="6" ClipToBounds="True">
                                                            <Image Source="{Binding AlbumArtUrl}" Stretch="UniformToFill"/>
                                                        </Border>

                                                        <!-- Track Info -->
                                                        <StackPanel Grid.Column="2" Margin="10,0,0,0" VerticalAlignment="Center">
                                                            <TextBlock Text="{Binding Name}" FontSize="14" FontWeight="SemiBold" Foreground="White" TextTrimming="CharacterEllipsis"/>
                                                            <TextBlock Text="{Binding Artist}" FontSize="12" Foreground="#52525b" TextTrimming="CharacterEllipsis"/>
                                                        </StackPanel>

                                                        <!-- Play Count -->
                                                        <TextBlock Grid.Column="3" FontSize="13" FontWeight="SemiBold" Foreground="{StaticResource SpotifyGreenBrush}" VerticalAlignment="Center" HorizontalAlignment="Center">
                                                            <Run Text="{Binding PlayCount}"/>
                                                            <Run Text=" kez" FontWeight="Normal" Foreground="#52525b"/>
                                                        </TextBlock>

                                                        <!-- Total Time -->
                                                        <TextBlock Grid.Column="4" Text="{Binding TotalListenedFormatted}" FontSize="12" 
                                                                   Foreground="#a1a1aa" VerticalAlignment="Center" HorizontalAlignment="Right"/>
                                                    </Grid>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </ScrollViewer>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Grid>

                <!-- Stats Page (Detailed) -->
                <Grid x:Name="StatsPage" Visibility="Collapsed">
                    <Border Style="{StaticResource GlassCard}">
                        <StackPanel>
                            <TextBlock Text="📊 Detaylı İstatistikler" FontSize="20" FontWeight="Bold" Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,20"/>
                            <TextBlock Text="Tüm dinleme geçmişiniz aşağıda listelenmiştir." FontSize="14" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,16"/>

                            <!-- Header row -->
                            <Grid Margin="0,0,0,8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="36"/>
                                    <ColumnDefinition Width="46"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="80"/>
                                    <ColumnDefinition Width="100"/>
                                    <ColumnDefinition Width="130"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="#" FontSize="12" FontWeight="SemiBold" Foreground="{StaticResource TextMutedBrush}" HorizontalAlignment="Center"/>
                                <TextBlock Grid.Column="2" Text="Şarkı" FontSize="12" FontWeight="SemiBold" Foreground="{StaticResource TextMutedBrush}"/>
                                <TextBlock Grid.Column="3" Text="Dinleme" FontSize="12" FontWeight="SemiBold" Foreground="{StaticResource TextMutedBrush}" HorizontalAlignment="Center"/>
                                <TextBlock Grid.Column="4" Text="Toplam Süre" FontSize="12" FontWeight="SemiBold" Foreground="{StaticResource TextMutedBrush}" HorizontalAlignment="Center"/>
                                <TextBlock Grid.Column="5" Text="Son Dinleme" FontSize="12" FontWeight="SemiBold" Foreground="{StaticResource TextMutedBrush}" HorizontalAlignment="Right"/>
                            </Grid>
                            <Border Height="1" Background="{StaticResource BorderBrush}" Margin="0,0,0,4"/>

                            <ScrollViewer MaxHeight="500" VerticalScrollBarVisibility="Auto">
                                <ItemsControl x:Name="AllTracksList">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Padding="8,10" CornerRadius="8" Margin="0,1">
                                                <Border.Style>
                                                    <Style TargetType="Border">
                                                        <Setter Property="Background" Value="Transparent"/>
                                                        <Style.Triggers>
                                                            <Trigger Property="IsMouseOver" Value="True">
                                                                <Setter Property="Background">
                                                                    <Setter.Value>
                                                                        <SolidColorBrush Color="White" Opacity="0.04"/>
                                                                    </Setter.Value>
                                                                </Setter>
                                                            </Trigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Border.Style>
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="36"/>
                                                        <ColumnDefinition Width="46"/>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="80"/>
                                                        <ColumnDefinition Width="100"/>
                                                        <ColumnDefinition Width="130"/>
                                                    </Grid.ColumnDefinitions>

                                                    <TextBlock Grid.Column="0" Text="{Binding Rank}" FontSize="14" FontWeight="SemiBold" 
                                                               Foreground="{Binding RankColor}" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                                                    <Border Grid.Column="1" Width="40" Height="40" CornerRadius="6" ClipToBounds="True">
                                                        <Image Source="{Binding AlbumArtUrl}" Stretch="UniformToFill"/>
                                                    </Border>
                                                    <StackPanel Grid.Column="2" Margin="10,0,0,0" VerticalAlignment="Center">
                                                        <TextBlock Text="{Binding Name}" FontSize="14" FontWeight="SemiBold" Foreground="White" TextTrimming="CharacterEllipsis"/>
                                                        <TextBlock Text="{Binding Artist}" FontSize="12" Foreground="#52525b" TextTrimming="CharacterEllipsis"/>
                                                    </StackPanel>
                                                    <TextBlock Grid.Column="3" FontSize="13" FontWeight="SemiBold" Foreground="{StaticResource SpotifyGreenBrush}" VerticalAlignment="Center" HorizontalAlignment="Center">
                                                        <Run Text="{Binding PlayCount}"/>
                                                        <Run Text=" kez" FontWeight="Normal" Foreground="#52525b"/>
                                                    </TextBlock>
                                                    <TextBlock Grid.Column="4" Text="{Binding TotalListenedFormatted}" FontSize="12" 
                                                               Foreground="#a1a1aa" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                                                    <TextBlock Grid.Column="5" Text="{Binding LastPlayedFormatted}" FontSize="12" 
                                                               Foreground="#52525b" VerticalAlignment="Center" HorizontalAlignment="Right"/>
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </ScrollViewer>
                        </StackPanel>
                    </Border>
                </Grid>

                <!-- Playlists Page -->
                <Grid x:Name="PlaylistsPage" Visibility="Collapsed">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Smart Actions -->
                    <Border Grid.Row="0" Style="{StaticResource GlassCard}" Margin="0,0,0,16">
                        <StackPanel>
                            <TextBlock Text="🧠 Akıllı Çalma Listesi Araçları" FontSize="18" FontWeight="Bold" Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,16"/>
                            <WrapPanel>
                                <Button Style="{StaticResource PrimaryButton}" Content="⭐ En Çok Dinlenenlerden Liste Oluştur" Click="CreateTopPlaylist_Click" Margin="0,0,8,8"/>
                                <Button Style="{StaticResource SecondaryButton}" Content="🔍 Tekrar Eden Şarkıları Bul" Click="FindDuplicates_Click" Margin="0,0,8,8"/>
                                <Button Style="{StaticResource SecondaryButton}" Content="🔄 Listeleri Yenile" Click="RefreshPlaylists_Click" Margin="0,0,8,8"/>
                            </WrapPanel>
                        </StackPanel>
                    </Border>

                    <!-- Playlists Grid -->
                    <Border Grid.Row="1" Style="{StaticResource GlassCard}">
                        <StackPanel>
                            <TextBlock Text="📋 Çalma Listeleriniz" FontSize="16" FontWeight="SemiBold" Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,12"/>
                            <ScrollViewer VerticalScrollBarVisibility="Auto">
                                <ItemsControl x:Name="PlaylistsGrid">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <WrapPanel/>
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Width="180" Margin="4,4" CornerRadius="12" Padding="12" Cursor="Hand">
                                                <Border.Style>
                                                    <Style TargetType="Border">
                                                        <Setter Property="Background">
                                                            <Setter.Value>
                                                                <SolidColorBrush Color="White" Opacity="0.03"/>
                                                            </Setter.Value>
                                                        </Setter>
                                                        <Style.Triggers>
                                                            <Trigger Property="IsMouseOver" Value="True">
                                                                <Setter Property="Background">
                                                                    <Setter.Value>
                                                                        <SolidColorBrush Color="White" Opacity="0.07"/>
                                                                    </Setter.Value>
                                                                </Setter>
                                                            </Trigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Border.Style>
                                                <StackPanel>
                                                    <Border Width="156" Height="156" CornerRadius="8" ClipToBounds="True" Margin="0,0,0,10" Background="#1a1a1a">
                                                        <Image Source="{Binding ImageUrl}" Stretch="UniformToFill"/>
                                                    </Border>
                                                    <TextBlock Text="{Binding Name}" FontSize="14" FontWeight="SemiBold" Foreground="White" TextTrimming="CharacterEllipsis"/>
                                                    <TextBlock Foreground="#52525b" FontSize="12" Margin="0,2,0,0">
                                                        <Run Text="{Binding TrackCount}"/>
                                                        <Run Text=" şarkı"/>
                                                    </TextBlock>
                                                </StackPanel>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </ScrollViewer>
                        </StackPanel>
                    </Border>
                </Grid>

                <!-- Settings Page -->
                <Grid x:Name="SettingsPage" Visibility="Collapsed">
                    <StackPanel MaxWidth="550" HorizontalAlignment="Center">
                        <Border Style="{StaticResource GlassCard}" Margin="0,0,0,16">
                            <StackPanel>
                                <TextBlock Text="⚙️ Spotify API Ayarları" FontSize="18" FontWeight="Bold" Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,16"/>

                                <TextBlock Text="Client ID" FontSize="13" FontWeight="Medium" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,6"/>
                                <TextBox x:Name="SettingsClientId" Style="{StaticResource ModernTextBox}" Margin="0,0,0,12"/>

                                <TextBlock Text="Client Secret" FontSize="13" FontWeight="Medium" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,6"/>
                                <TextBox x:Name="SettingsClientSecret" Style="{StaticResource ModernTextBox}" Margin="0,0,0,16"/>

                                <StackPanel Orientation="Horizontal">
                                    <Button Content="💾 Kaydet" Style="{StaticResource PrimaryButton}" Click="SaveSettings_Click" Margin="0,0,8,0"/>
                                    <Button Content="🔗 Yeniden Bağlan" Style="{StaticResource SecondaryButton}" Click="Reconnect_Click"/>
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <Border Style="{StaticResource GlassCard}">
                            <StackPanel>
                                <TextBlock Text="ℹ️ Hakkında" FontSize="16" FontWeight="SemiBold" Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,12"/>
                                <TextBlock TextWrapping="Wrap" FontSize="13" Foreground="{StaticResource TextSecondaryBrush}" LineHeight="22">
                                    <Run Text="Spotify Asistanı"/>
                                    <Run Text=" v1.0" Foreground="{StaticResource SpotifyGreenBrush}"/>
                                    <LineBreak/>
                                    <Run Text="Bu uygulama dinlediğiniz şarkıları yerel veritabanında takip eder."/>
                                    <LineBreak/>
                                    <Run Text="Verileriniz bilgisayarınızda saklanır, hiçbir yere gönderilmez."/>
                                </TextBlock>
                                <TextBlock Text="Redirect URI: http://127.0.0.1:8391/callback" FontSize="12" Foreground="{StaticResource TextMutedBrush}" Margin="0,12,0,0"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Grid>
            </Grid>
        </DockPanel>

        <!-- Toast Notification -->
        <Border x:Name="ToastPanel" Visibility="Collapsed" VerticalAlignment="Bottom" HorizontalAlignment="Right" 
                Margin="0,0,24,24" Padding="16,12" CornerRadius="12"
                BorderBrush="{StaticResource BorderBrush}" BorderThickness="1">
            <Border.Background>
                <SolidColorBrush Color="#191923" Opacity="0.95"/>
            </Border.Background>
            <Border.Effect>
                <DropShadowEffect BlurRadius="20" ShadowDepth="4" Opacity="0.4" Color="Black"/>
            </Border.Effect>
            <StackPanel Orientation="Horizontal">
                <TextBlock x:Name="ToastIcon" Text="✓" FontSize="16" Margin="0,0,10,0" VerticalAlignment="Center"/>
                <TextBlock x:Name="ToastMessage" Text="" FontSize="13" Foreground="{StaticResource TextPrimaryBrush}" VerticalAlignment="Center" MaxWidth="350" TextWrapping="Wrap"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>
